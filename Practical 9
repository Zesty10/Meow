import androidx.compose.ui.unit.dp
import com.example.fatima.ui.theme.FatimaTheme

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContent {
            FatimaTheme {
                Scaffold(modifier = Modifier.fillMaxSize()) { innerPadding ->
                    AppForm(
                        modifier = Modifier.padding(innerPadding)
                    )
                }
            }
        }
    }
}

@Composable
fun AppForm(modifier: Modifier = Modifier) {

    // State variables
    var name by remember { mutableStateOf("") }
    var gender by remember { mutableStateOf("") }
    var python by remember { mutableStateOf(false) }
    var kotlin by remember { mutableStateOf(false) }
    var selectedClass by remember { mutableStateOf("FYCS") }
    var welcomeMessage by remember { mutableStateOf("") }
    var languageMessage by remember { mutableStateOf("") }

    val classList = listOf("FYCS", "SYCS", "TYCS")

    Column(modifier = modifier.padding(20.dp)) {

        // NAME
        OutlinedTextField(
            value = name,
            onValueChange = { name = it },
            label = { Text("Name") }
        )

        Spacer(modifier = Modifier.height(20.dp))

        // GENDER
        Text(text = "Gender")
        Row {
            RadioButton(
                selected = (gender == "Male"),
                onClick = { gender = "Male" }
            )
            Text("Male")

            Spacer(modifier = Modifier.width(20.dp))

            RadioButton(
                selected = (gender == "Female"),
                onClick = { gender = "Female" }
            )
            Text("Female")
        }

        Spacer(modifier = Modifier.height(20.dp))

        // CHECKBOX LANGUAGE
        Text(text = "I Like")
        Row {
            Checkbox(checked = python, onCheckedChange = { python = it })
            Text("Python")

            Spacer(modifier = Modifier.width(20.dp))

            Checkbox(checked = kotlin, onCheckedChange = { kotlin = it })
            Text("Kotlin")
        }

        Spacer(modifier = Modifier.height(20.dp))

        // CLASS DROPDOWN
        var expanded by remember { mutableStateOf(false) }

        Box {
            Button(onClick = { expanded = true }) {
                Text("Your Class: $selectedClass")
            }

            DropdownMenu(
                expanded = expanded,
                onDismissRequest = { expanded = false }
            ) {
                classList.forEach { cls ->
                    DropdownMenuItem(
                        text = { Text(cls) },
                        onClick = {
                            selectedClass = cls
                            expanded = false
                        }
                    )
                }
            }
        }

        Spacer(modifier = Modifier.height(20.dp))

        // SUBMIT BUTTON
        Button(onClick = {
            welcomeMessage = "Welcome $name"

            languageMessage = when {
                python && kotlin -> "You love both languages"
                python -> "You love Python"
                kotlin -> "You love Kotlin"
                else -> "You don't like these languages"
            }

        }) {
            Text("Submit")
        }

        Spacer(modifier = Modifier.height(20.dp))

        Text(text = welcomeMessage)
        Text(text = "Gender: $gender")
        Text(text = "Class: $selectedClass")
        Text(text = languageMessage)
    }
}

