Aim: Create media player Application in android that plays audio. Implement play ,Pause, Loop features.

main.kt

package com.example.practical15

import android.media.MediaPlayer
import android.os.Bundle
import android.widget.Button
import androidx.activity.ComponentActivity
import com.example.practical15.R

class MainActivity : ComponentActivity() {

    private lateinit var mediaPlayer: MediaPlayer
    private var isLooping = false

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.layout)

        mediaPlayer = MediaPlayer.create(this, R.raw.music)

        val btnPlay = findViewById<Button>(R.id.btnPlay)
        val btnPause = findViewById<Button>(R.id.btnPause)
        val btnLoop = findViewById<Button>(R.id.btnLoop)

        btnPlay.setOnClickListener {
            if (!mediaPlayer.isPlaying) {
                mediaPlayer.start()
            }
        }

        btnPause.setOnClickListener {
            if (mediaPlayer.isPlaying) {
                mediaPlayer.pause()
            }
        }

        btnLoop.setOnClickListener {
            isLooping = !isLooping
            mediaPlayer.isLooping = isLooping
        }
    }

    override fun onDestroy() {
        super.onDestroy()
        mediaPlayer.release()
    }
}


