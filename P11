package com.example.practical11

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.activity.enableEdgeToEdge
import androidx.compose.foundation.layout.*
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Modifier
import androidx.compose.ui.tooling.preview.Preview
import androidx.compose.ui.unit.dp
import com.example.practical11.ui.theme.Practical11Theme

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()

        val sharedPref = getSharedPreferences("MyPrefs", MODE_PRIVATE)

        setContent {

            var savedName by remember { mutableStateOf("") }
            var savedClass by remember { mutableStateOf("") }

            Practical11Theme {
                Scaffold(modifier = Modifier.fillMaxSize()) { innerPadding ->

                    Column(
                        modifier = Modifier
                            .padding(innerPadding)
                            .padding(20.dp)
                            .fillMaxWidth(),
                        verticalArrangement = Arrangement.Top
                    ) {

                        var inputName by remember { mutableStateOf("") }
                        var inputClass by remember { mutableStateOf("") }

                        // Input Field 1 : Name
                        OutlinedTextField(
                            value = inputName,
                            onValueChange = { inputName = it },
                            label = { Text("Enter Name") },
                            modifier = Modifier.fillMaxWidth()
                        )

                        Spacer(modifier = Modifier.height(12.dp))

                        // Input Field 2 : Class
                        OutlinedTextField(
                            value = inputClass,
                            onValueChange = { inputClass = it },
                            label = { Text("Enter Class") },
                            modifier = Modifier.fillMaxWidth()
                        )

                        Spacer(modifier = Modifier.height(20.dp))

                        // SET Button
                        Button(
                            onClick = {
                                sharedPref.edit()
                                    .putString("username", inputName)
                                    .putString("userclass", inputClass)
                                    .apply()
                            },
                            modifier = Modifier.fillMaxWidth()
                        ) {
                            Text("SET (Save Values)")
                        }

                        Spacer(modifier = Modifier.height(10.dp))

                        // GET Button
                        Button(
                            onClick = {
                                savedName = sharedPref.getString("username", "Not Found") ?: ""
                                savedClass = sharedPref.getString("userclass", "Not Found") ?: ""
                            },
                            modifier = Modifier.fillMaxWidth()
                        ) {
                            Text("GET (Fetch Values)")
                        }

                        Spacer(modifier = Modifier.height(30.dp))

                        Greeting(
                            name = "Name: $savedName | Class: $savedClass",
                            modifier = Modifier
                        )
                    }
                }
            }
        }
    }
}

@Composable
fun Greeting(name: String, modifier: Modifier = Modifier) {
    Text(
        text = "Hello, $name",
        modifier = modifier
    )
}

@Preview(showBackground = true)
@Composable
fun GreetingPreview() {
    Practical11Theme {
        Greeting("Android")
    }
