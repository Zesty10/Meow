Aim: Write a program using Kotlin to implement function overloading.

A. class Calculator {
    fun add(a: Int, b: Int): Int {
        return a + b
    }
    
    fun add(a: Double, b: Double): Double {
        return a + b
    }
    
    fun add(a: Int, b: Int, c: Int): Int {
        return a + b + c
    }
}

fun main() {
    val calculator = Calculator()

    val sum1 = calculator.add(5, 10)
    println("Sum of 5 and 10: $sum1")

    val sum2 = calculator.add(2.5, 3.7)
    println("Sum of 2.5 and 3.7: $sum2")

    val sum3 = calculator.add(1, 2, 3)
    println("Sum of 1, 2, and 3: $sum3")
}


B. fun greet(name: String, age: Int) {
    println("Hello, $name. You are $age years old.")
}

fun greet(name: String) {
    println("Welcome, $name. to Android Programming")
}

fun main() {
    println(greet("Pramitha", 38)) // Calls first "greet" function
    println(greet("Pramitha")) // Calls second "greet" function
}

